APP_ENV=development

# No-Docker local PostgreSQL development.
DATABASE_URL=postgresql+psycopg://resume_match:resume_match@localhost:5432/resume_match
POSTGRES_DB=resume_match
POSTGRES_USER=resume_match
POSTGRES_PASSWORD=resume_match

BACKEND_CORS_ORIGINS=http://localhost:3000
WEB_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8000
RESUME_STORAGE_DIR=backend/app/storage/resumes

# Google OAuth. Create these in Google Cloud Console.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback
